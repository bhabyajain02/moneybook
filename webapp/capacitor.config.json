{
  "appId": "com.moneybook.app",
  "appName": "MoneyBook",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#075E54",
      "showSpinner": false
    },
    "StatusBar": {
      "backgroundColor": "#075E54",
      "style": "DARK"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
