{
  "expo": {
    "name": "MoneyBook",
    "slug": "moneybook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00695C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moneybook.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MoneyBook uses your camera to scan khata/ledger pages.",
        "NSPhotoLibraryUsageDescription": "MoneyBook reads photos to scan ledger entries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00695C"
      },
      "package": "com.moneybook.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "MoneyBook reads photos to scan ledger entries.",
          "cameraPermission": "MoneyBook uses your camera to scan khata pages."
        }
      ]
    ]
  }
}
